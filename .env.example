# DSTEP Enterprise v0.1.0-alpha
# Copy this file to .env and fill in your own values
# NEVER commit .env file to Git

# ============================================================================
# DJANGO CONFIGURATION
# ============================================================================
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production-min-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ============================================================================
# ENVIRONMENT (development, staging, production)
# ============================================================================
ENVIRONMENT=development

# ============================================================================
# DATABASE POSTGRESQL
# ============================================================================
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=dstep_db
DATABASE_USER=dstep_user
DATABASE_PASSWORD=change-this-password-in-production

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@dstepglobal.com

# ============================================================================
# DOCKER PORTS (CONFIGURABLE)
# ============================================================================
BACKEND_PORT=8000
BUSINESS_PORTAL_PORT=3000
CONTROL_CENTER_PORT=3001
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=DSTEP Enterprise
APP_VERSION=0.1.0-alpha
COMPANY_VERIFICATION_REQUIRED=False
KYB_REQUIRED=False
KYC_REQUIRED=False

# ============================================================================
# AWS S3 (OPTIONAL)
# ============================================================================
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ============================================================================
# STRIPE (OPTIONAL)
# ============================================================================
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================================================
# SENTRY (OPTIONAL)
# ============================================================================
SENTRY_DSN=

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
VITE_API_BASE_URL=http://localhost:8000/api/
REACT_APP_API_BASE_URL=http://localhost:8000/api/
REACT_APP_ENV=development
