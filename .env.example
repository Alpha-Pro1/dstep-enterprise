# DSTEP Enterprise Environment Configuration
# Copy this file to .env and update values for your environment

# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production-12345678901234567890
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.development

# Database
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=dstep_db
DATABASE_USER=dstep_user
DATABASE_PASSWORD=dstep_password_change_me
POSTGRES_DB=dstep_db
POSTGRES_USER=dstep_user
POSTGRES_PASSWORD=dstep_password_change_me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@dstepglobal.com

# AWS S3 (Optional)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Stripe (Optional)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend URLs
VITE_API_BASE_URL=http://localhost:8000/api/
REACT_APP_API_BASE_URL=http://localhost:8000/api/

# Application Settings
COMPANY_VERIFICATION_REQUIRED=False
KYB_REQUIRED=False
KYC_REQUIRED=False

# Logging
LOG_LEVEL=INFO

# Application Name
APP_NAME=DSTEP Enterprise
APP_VERSION=0.1.0-alpha

# Server Configuration
SERVER_PORT=8000
SERVER_HOST=0.0.0.0
